{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/*.backup",
      "**/*.bak",
      "**/*.md",
      "!README.md",
      "**/backup_*/**",
      "**/*-dev.js",
      "**/*-debug.js",
      "**/*-test.js",
      "*.py",
      "*.pyc",
      "*.sh",
      "*.bat",
      "*.gs",
      "console-log-replacement-report.txt",
      "DEPLOY-INSTRUCTIONS.txt",
      "DEPLOYMENT-CHECKLIST.txt",
      "css/LOAD-ORDER.txt",
      "server.js",
      "server.ext",
      "https-server.py",
      "https-server.js",
      "start-dev.sh",
      "bs-config.js",
      "build-*.js",
      "safe-*.js",
      "cleanup-*.sh",
      "**/build-*.js",
      "**/safe-*.js",
      "package.json",
      "package-lock.json",
      ".git/**",
      ".gitignore",
      ".env*",
      "certs/**",
      "**/*.pem",
      "localhost.pem",
      "google-apps-script*.js",
      "**/*-fixed.js",
      "*.pdf",
      "functions/**",
      "**/*.backup2",
      "**/*.backup3",
      "**/*.backup4",
      "**/*.pre-revert",
      "**/*-original.*",
      "modal-test.html",
      "email-template-preview.html",
      "**/.*/**",
      "**/*.backup*",
      "firestore.rules",
      "firestore.indexes.json"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=31536000; includeSubDomains"
          },
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin-allow-popups"
          },
          {
            "key": "Content-Security-Policy-Report-Only",
            "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.chatbase.co https://www.chatbase.co https://www.googletagmanager.com https://web.squarecdn.com https://js.squarecdn.com https://www.clarity.ms https://c.bing.com; connect-src 'self' https://www.chatbase.co https://www.google-analytics.com https://region1.google-analytics.com https://analytics.google.com https://www.clarity.ms; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; frame-src https://squareup.com https://web.squarecdn.com https://www.chatbase.co https://www.google.com; worker-src blob:;"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|webp|svg|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          },
          {
            "key": "Service-Worker-Allowed",
            "value": "/"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/blog/transparent-pricing-columbus-dumpster-rental",
        "destination": "/blog/posts/same-day-dumpster-delivery-columbus",
        "type": 301
      },
      {
        "source": "/blog/dumpster-placement-tips-property-guide",
        "destination": "/blog/posts/ohio-dumpster-permit-guide",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/api/processBooking",
        "run": { "serviceId": "processbooking", "region": "us-central1" }
      },
      {
        "source": "/api/checkAvailability",
        "run": { "serviceId": "checkavailability", "region": "us-central1" }
      },
      {
        "source": "/api/getFullyBookedDates",
        "run": { "serviceId": "getfullybookeddates", "region": "us-central1" }
      },
      {
        "source": "/api/createManualBooking",
        "run": { "serviceId": "createmanualbooking", "region": "us-central1" }
      },
      {
        "source": "/api/processDumpAndReturn",
        "run": { "serviceId": "processdumpandreturn", "region": "us-central1" }
      },
      {
        "source": "/api/recordWeighIn",
        "run": { "serviceId": "recordweighin", "region": "us-central1" }
      },
      {
        "source": "/api/settleStatement",
        "run": { "serviceId": "settlestatement", "region": "us-central1" }
      },
      {
        "source": "/api/getStatements",
        "run": { "serviceId": "getstatements", "region": "us-central1" }
      }
    ]
  }
}
