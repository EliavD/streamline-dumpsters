{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/*.backup",
      "**/*.bak",
      "**/*.md",
      "!README.md",
      "**/backup_*/**",
      "**/*-dev.js",
      "**/*-debug.js",
      "**/*-test.js",
      "*.py",
      "*.pyc",
      "*.sh",
      "*.bat",
      "*.gs",
      "*.txt",
      "!robots.txt",
      "server.js",
      "server.ext",
      "https-server.py",
      "https-server.js",
      "start-dev.sh",
      "bs-config.js",
      "build-*.js",
      "safe-*.js",
      "cleanup-*.sh",
      "**/build-*.js",
      "**/safe-*.js",
      "package.json",
      "package-lock.json",
      ".git/**",
      ".gitignore",
      ".env*",
      "certs/**",
      "**/*.pem",
      "localhost.pem"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "redirects": [
      {
        "source": "**",
        "destination": "https://sl-dumpsters.com/:splat",
        "type": 301,
        "headers": [
          {
            "key": "Host",
            "value": "www.sl-dumpsters.com"
          }
        ]
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600, s-maxage=7200"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|webp|svg|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400, s-maxage=2592000"
          }
        ]
      },
      {
        "source": "**/*.@(html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600, must-revalidate"
          }
        ]
      },
      {
        "source": "sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          },
          {
            "key": "Service-Worker-Allowed",
            "value": "/"
          }
        ]
      }
    ],
    "rewrites": []
  }
}
